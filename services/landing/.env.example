# Copy to .env.local. Never commit .env.local.

# ── Clerk ────────────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Optional sign-in/up redirects (defaults: /dashboard)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── vlabs-api backend ────────────────────────────────────────────────
# Default for local dev — points at the FastAPI service on :8000.
# Production: https://api.verifiable-labs.com
NEXT_PUBLIC_VLABS_API_URL=http://localhost:8000
