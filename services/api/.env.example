# Copy to .env.local and fill in. Never commit .env.local.
# Stage A only requires DATABASE_URL and VLABS_API_KEY_HASH_PEPPER.

# ── Required ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vlabs:vlabs@localhost:5433/vlabs
VLABS_API_KEY_HASH_PEPPER=replace-me-with-32-bytes-of-base64-entropy

# ── Optional ─────────────────────────────────────────────────────────
VLABS_LOG_LEVEL=INFO
VLABS_ENVIRONMENT=dev

# ── Stage B: Stripe (TEST MODE ONLY until Delaware C-corp resolves) ─
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me

# Created via `scripts/create_stripe_products.py` (run once with sk_test_)
STRIPE_PRICE_ID_PRO=price_replace_me
STRIPE_PRICE_ID_TEAM=price_replace_me
STRIPE_PRICE_ID_PRO_OVERAGE=price_replace_me
STRIPE_PRICE_ID_TEAM_OVERAGE=price_replace_me

# Created when you add the webhook endpoint in Stripe Dashboard.
# For local dev: `stripe listen --forward-to localhost:8000/v1/billing/webhook`
# prints the whsec_ secret.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Where the user lands after Checkout / Portal flows.
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:3000/dashboard/billing
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/dashboard/billing?status=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/dashboard/billing?status=cancel

# ── Stage B: Clerk (dashboard auth) ─────────────────────────────────
# Get from https://dashboard.clerk.com -> API Keys
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_PUBLISHABLE_KEY=pk_test_replace_me
# Your Clerk instance issuer URL (visible in dashboard -> JWT templates)
# e.g. https://romantic-dolphin-12.clerk.accounts.dev
CLERK_JWT_ISSUER=
CLERK_JWKS_URL=

# ── Optional observability ──────────────────────────────────────────
SENTRY_DSN=
