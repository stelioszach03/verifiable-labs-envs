# Copy to .env.local and fill in. Never commit .env.local.
# Stage A only requires DATABASE_URL and VLABS_API_KEY_HASH_PEPPER.

# ── Required ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vlabs:vlabs@localhost:5433/vlabs
VLABS_API_KEY_HASH_PEPPER=replace-me-with-32-bytes-of-base64-entropy

# ── Optional ─────────────────────────────────────────────────────────
VLABS_LOG_LEVEL=INFO
VLABS_ENVIRONMENT=dev

# ── Stage B (Stripe; placeholders until C-corp registered) ──────────
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID_PRO=price_replace_me
STRIPE_PRICE_ID_TEAM=price_replace_me

# ── Stage B (Clerk for dashboard auth) ──────────────────────────────
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_JWT_KEY=replace_me

# ── Optional observability ──────────────────────────────────────────
SENTRY_DSN=
