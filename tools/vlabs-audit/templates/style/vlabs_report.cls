%% vlabs_report.cls — LaTeX class for Verifiable Labs capability reports.
%%
%% Loaded by templates/main.tex.j2; the Python renderer copies this
%% file alongside the rendered main.tex into the tectonic working dir.
%%
\NeedsTeXFormat{LaTeX2e}
\ProvidesClass{vlabs_report}[2026/05/01 v0.1 Verifiable Labs audit report]

\LoadClass[11pt,letterpaper]{article}

%% ── Page geometry ────────────────────────────────────────────────
\RequirePackage[margin=1in]{geometry}

%% ── Fonts: serif body, sans-serif headers ────────────────────────
\RequirePackage[T1]{fontenc}
\RequirePackage{lmodern}
\RequirePackage[default,scale=0.95]{lato} % sans family default but body uses serif via \rmfamily
\renewcommand{\familydefault}{\rmdefault}  % keep body serif; \sffamily for headers

%% ── Typography polish: protrusion + expansion + saner line breaks ─
%% microtype reduces ragged-right rivers and over-aggressive hyphenation.
%% ``\hyphenpenalty`` pushes TeX away from breaking words at line ends;
%% ``\tolerance`` lets it stretch line spacing slightly more before
%% inserting an awkward hyphen.
\RequirePackage{microtype}
\hyphenpenalty=5000
\tolerance=1000

%% ── Colour palette ───────────────────────────────────────────────
\RequirePackage{xcolor}
\definecolor{vlabsdarkblue}{rgb}{0.05, 0.20, 0.45}
\definecolor{vlabsmidgrey}{rgb}{0.35, 0.35, 0.35}

%% ── Math + tables ────────────────────────────────────────────────
\RequirePackage{amsmath}  % \text{} inside $...$
\RequirePackage{booktabs}
\RequirePackage{array}

%% ── Graphics ─────────────────────────────────────────────────────
\RequirePackage{graphicx}
\RequirePackage{float}  % \begin{figure}[H] support

%% ── Hyperlinks ───────────────────────────────────────────────────
\RequirePackage[colorlinks=true,
                linkcolor=vlabsdarkblue,
                urlcolor=vlabsdarkblue,
                citecolor=vlabsdarkblue]{hyperref}

%% ── Header/footer ────────────────────────────────────────────────
\RequirePackage{fancyhdr}
\newcommand{\vlabsauditid}{\textit{audit id not set}}
\newcommand{\setvlabsaudit}[1]{\renewcommand{\vlabsauditid}{#1}}

\pagestyle{fancy}
\fancyhf{}
\fancyfoot[L]{\small\sffamily\textcolor{vlabsmidgrey}{vlabs-audit}}
\fancyfoot[C]{\small\sffamily\textcolor{vlabsmidgrey}{\texttt{\vlabsauditid}}}
\fancyfoot[R]{\small\sffamily\textcolor{vlabsmidgrey}{page \thepage}}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0.4pt}

%% Cover page uses the empty page style.
\fancypagestyle{vlabscover}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
}

%% ── Section formatting with thin rule ────────────────────────────
\RequirePackage{titlesec}
\titleformat{\section}
  {\sffamily\Large\bfseries\color{vlabsdarkblue}}
  {\thesection.}{0.6em}{}[{\vspace{2pt}\hrule height 0.4pt}]
\titleformat{\subsection}
  {\sffamily\large\bfseries\color{vlabsdarkblue!85!black}}
  {\thesubsection.}{0.5em}{}
\titleformat{\subsubsection}
  {\sffamily\normalsize\bfseries\color{vlabsmidgrey}}
  {}{0pt}{}

%% ── Cover page macro: \makevlabscover{title}{model}{date} ────────
\newcommand{\makevlabscover}[3]{%
  \thispagestyle{vlabscover}%
  \begin{titlepage}
    \centering
    \vspace*{2.5cm}
    {\sffamily\Huge\bfseries\color{vlabsdarkblue} #1\par}
    \vspace{0.3cm}
    {\sffamily\Large\textcolor{vlabsmidgrey} {Capability audit report}\par}
    \vspace{2.5cm}
    \rule{0.55\textwidth}{0.6pt}\par
    \vspace{1cm}
    {\sffamily\Large Model under audit\par}
    \vspace{0.3cm}
    {\sffamily\Huge\bfseries #2\par}
    \vspace{2cm}
    \rule{0.55\textwidth}{0.6pt}\par
    \vspace{1cm}
    {\sffamily\large #3\par}
    \vspace{0.4cm}
    {\footnotesize\sffamily\textcolor{vlabsmidgrey}{Generated by \texttt{vlabs-audit}}\par}
    \vspace{0.2cm}
    {\footnotesize\texttt{\vlabsauditid}\par}
    \vfill
  \end{titlepage}
  \cleardoublepage
}

%% ── Misc ─────────────────────────────────────────────────────────
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.5em}

\endinput
